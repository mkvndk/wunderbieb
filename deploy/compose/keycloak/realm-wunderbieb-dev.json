  ],
  "clientScopes": [
    {
      "name": "wunderbieb-claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "user_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "user_id",
            "jsonType.label": "long"
          }
        },
        {
          "name": "role_code",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "role_code",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role_code",
            "jsonType.label": "String"
          }
        },
        {
          "name": "scope_type",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "scope_type",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "scope_type",
            "jsonType.label": "String"
          }
        },
        {
          "name": "board_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "board_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "board_id",
            "jsonType.label": "long"
          }
        },
        {
          "name": "school_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
