  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "clients": [
    {
      "clientId": "wunderbieb-ui",
      "name": "Wunderbieb UI",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "defaultClientScopes": [
        "wunderbieb-claims"
      ],
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:15173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:15173"
      ]
    },
    {
      "clientId": "wunderbieb-cli",
      "name": "Wunderbieb CLI",
